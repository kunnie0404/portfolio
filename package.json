{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "prepare:home": "node scripts/prepare-next-home.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "dev": "pnpm run prepare:home && next dev",
    "build": "pnpm run prepare:home && next build",
    "start": "next start",
    "test": "pnpm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "check": "pnpm run lint && pnpm run test"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "sharp": "0.34.5",
    "typescript": "5.9.3"
  },
  "type": "module"
}
